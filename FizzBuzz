#My first challenge was to try and solve FizzBuzz.
#Count from 1 to 100. For each digit divisible by 3, write "Fizz". For each digit divisible by 5, write "Buzz". For those digits which are divisible by both, write "FizzBuzz".

i = 1

while i <= 100:
    if (i % 3 == 0) & (i % 5 ==0):
        print("FizzBuzz")
        i += 1
    elif i % 3 == 0:
        print("Fizz")
        i += 1
    elif i % 5 == 0:
        print("Buzz")
        i += 1
    else:
        print(i)
        i += 1
