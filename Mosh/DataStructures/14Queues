# imports the deque class from collections
from collections import deque
# sets queue equal to deque, with an empty list inside
queue = deque([])
# the next three lines append the numbers 1, 2, and 3 into the queue list
queue.append(1)
queue.append(2)
queue.append(3)
# Similar to using the pop command to remove the last object in a list, popleft removes the first
queue.popleft()
queue.popleft()
# prints the remaining list of queue
# print(queue)
# if queue were empty, the following would be True and it would print "Empty"
if not queue:
    print("Empty")
else:
    print(queue)
